# Network: "devnet" | "testnet" | "mainnet" (default: devnet)
NEXT_PUBLIC_NETWORK=devnet

# CKB RPC URL (optional - defaults per network)
# NEXT_PUBLIC_CKB_RPC_URL=http://127.0.0.1:8114

# Indexer API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Contract addresses (override after deploying to testnet/mainnet)
# NEXT_PUBLIC_CAMPAIGN_CODE_HASH=0x...
# NEXT_PUBLIC_CAMPAIGN_TX_HASH=0x...
# NEXT_PUBLIC_PLEDGE_CODE_HASH=0x...
# NEXT_PUBLIC_PLEDGE_TX_HASH=0x...

# Devnet only: select which test account to auto-connect (0 or 1)
# NEXT_PUBLIC_DEVNET_ACCOUNT=0
