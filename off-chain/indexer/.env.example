# CKB RPC URL (default: http://127.0.0.1:8114)
CKB_RPC_URL=http://127.0.0.1:8114

# API server port
PORT=3001

# SQLite database path
DB_PATH=./data/indexer.db

# Background polling interval in ms
POLL_INTERVAL=10000

# Contract code hashes (override after deploying to testnet/mainnet)
# CAMPAIGN_CODE_HASH=0x...
# PLEDGE_CODE_HASH=0x...
