{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "ts-node": {
    "transpileOnly": true,
    "scopeDir": "../"
  },
  "include": ["src/**/*", "../transaction-builder/src/**/*"],
  "exclude": ["node_modules", "../transaction-builder/node_modules"]
}
